    {"type": "text", "id": "code_text", "x": 55, "y": 295, "width": 530, "height": 160, "text": "// Agent generates with domain context:\n\nexport default function AnalyticsDashboard() {\n  // Uses Recharts (user preference)\n  // Next.js 14 app router (project context)\n  // OKLCH colors (impeccable constraint)\n  // 4pt spacing grid (impeccable constraint)\n  // 44px touch targets (impeccable constraint)", "originalText": "// Agent generates with domain context:\n\nexport default function AnalyticsDashboard() {\n  // Uses Recharts (user preference)\n  // Next.js 14 app router (project context)\n  // OKLCH colors (impeccable constraint)\n  // 4pt spacing grid (impeccable constraint)\n  // 44px touch targets (impeccable constraint)", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#3fb950", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 80, "angle": 0, "seed": 500003, "version": 1, "versionNonce": 500004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "code_box", "lineHeight": 1.25},

